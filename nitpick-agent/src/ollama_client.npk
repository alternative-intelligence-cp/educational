    int32:prop_conf_time = raw json_create_object();
    drop json_object_set(prop_conf_time, "type", raw json_create_string("integer"));
    drop json_object_set(props_time, "confidence", prop_conf_time);
    drop json_object_set(func_params_time, "properties", props_time);
    drop json_object_set(func_obj_time, "parameters", func_params_time);
    drop json_object_set(tool_obj_time, "type", raw json_create_string("function"));
    drop json_object_set(tool_obj_time, "function", func_obj_time);
    drop json_array_append(tools_arr, tool_obj_time);

