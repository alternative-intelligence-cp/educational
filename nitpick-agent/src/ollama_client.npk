use "nitpick_http.npk";
use "nitpick_json.npk";

// Hardcoded for milestone 1
fixed string:OLLAMA_LOCAL_URL = "http://localhost:11434/api/chat";
fixed string:OLLAMA_EMBED_URL = "http://localhost:11434/api/embeddings";

//! Generates embeddings for a given text.
pub func:generate_embedding = string(string:model, string:text) {
    int32:root = raw json_create_object();
    int32:model_val = raw json_create_string(model);
    int32:prompt_val = raw json_create_string(text);
    
    drop json_object_set(root, "model", model_val);
    drop json_object_set(root, "prompt", prompt_val);
    
    drop json_serialize(root);
    string:payload = raw json_last_result();
    drop json_builder_clear();

    int32:init_res = raw http_init();
    drop http_clear_headers();
    drop http_set_header("Content-Type: application/json");
    
    int32:post_res = raw http_post(OLLAMA_EMBED_URL, payload);
    string:resp_body = raw http_body();
    drop http_cleanup();
    
    int64:start_idx = string_index_of(resp_body, "[");
    int64:end_idx = string_index_of(resp_body, "]");
    if (start_idx >= 0i64) {
        if (end_idx > start_idx) {
            string:arr_str = string_substring(resp_body, start_idx, end_idx + 1i64);
            pass(arr_str);
        }
    }
    pass("");
};

//! Generates a chat response from Ollama.
//!
//! @param model           The Ollama model name (e.g. "llama3")
//! @param system_prompt   The system instructions
//! @param user_msg        The user's prompt
//! @returns               response string
pub func:generate_chat = string(string:model, string:history, string:dashboard_state, string:role_prompt) {
    // 1. Build JSON payload natively using the builder API
    int32:history_arr = raw json_parse_to_builder(history);
    
    if (string_length(dashboard_state) > 0i64) {
        int32:dash_msg = raw json_create_object();
        drop json_object_set(dash_msg, "role", raw json_create_string("system"));
        drop json_object_set(dash_msg, "content", raw json_create_string(string_concat("[SYSTEM DASHBOARD]\n", dashboard_state)));
        drop json_array_append(history_arr, dash_msg);
    }
    
    if (string_length(role_prompt) > 0i64) {
        int32:role_msg = raw json_create_object();
        drop json_object_set(role_msg, "role", raw json_create_string("system"));
        drop json_object_set(role_msg, "content", raw json_create_string(string_concat("[ACTIVE ROLE]\n", role_prompt)));
        drop json_array_append(history_arr, role_msg);
    }
    
    int32:root = raw json_create_object();
    int32:model_val = raw json_create_string(model);
    int32:stream_val = raw json_create_bool(1i32);
    
    drop json_object_set(root, "model", model_val);
    drop json_object_set(root, "stream", stream_val);
    drop json_object_set(root, "messages", history_arr);
    
    // Define Tools
    int32:tools_arr = raw json_create_array();
    
    // Tool: get_system_time
    int32:tool_obj_time = raw json_create_object();
    int32:func_obj_time = raw json_create_object();
    drop json_object_set(func_obj_time, "name", raw json_create_string("get_system_time"));
