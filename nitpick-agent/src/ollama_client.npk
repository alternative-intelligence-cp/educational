    drop json_object_set(func_params_create, "type", raw json_create_string("object"));
    int32:props_create = raw json_create_object();
    int32:prop_name = raw json_create_object();
    drop json_object_set(prop_name, "type", raw json_create_string("string"));
    drop json_object_set(props_create, "snapshot_name", prop_name);
    int32:prop_conf_c = raw json_create_object();
    drop json_object_set(prop_conf_c, "type", raw json_create_string("integer"));
    drop json_object_set(props_create, "confidence", prop_conf_c);
    drop json_object_set(func_params_create, "properties", props_create);
    drop json_object_set(func_obj_create, "parameters", func_params_create);
    drop json_object_set(tool_obj_create, "type", raw json_create_string("function"));
