    int32:t_rep_old = raw json_create_object();
    drop json_object_set(t_rep_old, "type", raw json_create_string("string"));
    int32:t_rep_new = raw json_create_object();
    drop json_object_set(t_rep_new, "type", raw json_create_string("string"));
    drop json_object_set(t_rep_props, "path", t_rep_path);
    drop json_object_set(t_rep_props, "old_text", t_rep_old);
    drop json_object_set(t_rep_props, "new_text", t_rep_new);
    drop json_object_set(t_rep_p, "properties", t_rep_props);
    int32:t_rep_req = raw json_create_array();
    drop json_array_append(t_rep_req, raw json_create_string("path"));
    drop json_array_append(t_rep_req, raw json_create_string("old_text"));
    drop json_array_append(t_rep_req, raw json_create_string("new_text"));
    drop json_object_set(t_rep_p, "required", t_rep_req);
    drop json_object_set(t_rep_f, "parameters", t_rep_p);
    drop json_object_set(t_rep, "function", t_rep_f);
    drop json_array_append(tools_arr, t_rep);

    drop json_object_set(root, "tools", tools_arr);
    
    drop json_serialize(root);
    string:payload = raw json_last_result();
    drop json_builder_clear();

    // 2. Setup HTTP
    int32:init_res = raw http_init();
    drop http_clear_headers();
    drop http_set_header("Content-Type: application/json");

    // 3. POST
    drop http_enable_ollama_stream(1i32);
    int32:post_res = raw http_post(OLLAMA_LOCAL_URL, payload);
    drop http_enable_ollama_stream(0i32);
    
    // 4. Check status
    int32:status = raw http_status();
    if (status != 200i32) {
        string:err_body = raw http_body();
        drop http_cleanup();
        pass(err_body);
    }

    // 5. Get streamed tool calls
    string:tool_call = raw http_get_ollama_tool();
    if (string_length(tool_call) > 0i64) {
        string:tool_arg = raw http_get_ollama_arg();
        int32:tool_conf_int = raw http_get_ollama_conf();
        string:tool_conf = string_from_int(@cast<int64>(tool_conf_int));
        drop http_cleanup();
        pass(string_concat(string_concat("TOOL:", tool_conf), string_concat(string_concat(":", tool_call), string_concat(":", tool_arg))));
    }
    
    // 6. Get streamed content
    string:content = raw http_get_ollama_content();
    drop http_cleanup();
    
    string:trimmed_content = string_trim(content);
    int64:args_idx = string_index_of(trimmed_content, "[ARGS]");
    if (args_idx > 0i64) {
        string:fallback_name = string_trim(string_substring(trimmed_content, 0i64, args_idx));
        string:fallback_arg = string_trim(string_substring(trimmed_content, args_idx + 6i64, string_length(trimmed_content)));
        pass(string_concat("TOOL:0:", string_concat(fallback_name, string_concat(":", fallback_arg))));
    }

    pass(string_concat("TEXT:", content));
};
